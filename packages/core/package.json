{
  "name": "branchreel",
  "version": "1.0.0",
  "description": "Branching video on a page you control: drop in your clips and a JSON graph for click-to-branch playback. No platform, no backend.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "video",
    "interactive-video",
    "branching",
    "state-machine"
  ],
  "author": "Charlie Krug",
  "repository": {
    "type": "git",
    "url": "https://github.com/ctkrug/branchreel.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
